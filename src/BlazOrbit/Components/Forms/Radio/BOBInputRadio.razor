@namespace BlazOrbit.Components.Forms
@attribute [GenerateComponentInfo]
@inherits BOBInputComponentBase<TValue, BOBInputRadio<TValue>, BOBInputRadioVariant>
@implements IBuiltComponent
@implements IRadioContainer
@implements IHasSize
@implements IHasColor
@typeparam TValue

@{
    base.BuildRenderTree(__builder);
}

<CascadingValue Value="@((IRadioContainer)this)" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private readonly List<IRadioOption> _options = [];
    private readonly string _groupName = $"radio-{Guid.NewGuid():N}";
    private string _helperTextId = $"bob-helper-{Guid.NewGuid():N}";
    private bool _preventKeyDefault;
    private TValue _initialValue = default!;

    private readonly Type _elementType;

    private static readonly bool IsNullableType =
        !typeof(TValue).IsValueType || Nullable.GetUnderlyingType(typeof(TValue)) != null;

    /// <summary>Content rendered inside the component.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Visual size of the component.</summary>
    [Parameter] public BOBSize Size { get; set; } = BOBSize.Medium;
    /// <summary>Text or foreground color. Accepts any valid CSS color value.</summary>
    [Parameter] public string? Color { get; set; }
    /// <summary>Floating label displayed above the component.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Helper text displayed below the component for additional context.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Clearable.</summary>
    [Parameter] public bool Clearable { get; set; }
    /// <summary>Text displayed as the Clear.</summary>
    [Parameter] public string ClearText { get; set; } = "Clear";
    /// <summary>Material icon name for the Checked.</summary>
    [Parameter] public IconKey? CheckedIcon { get; set; }
    /// <summary>Material icon name for the Unchecked.</summary>
    [Parameter] public IconKey? UncheckedIcon { get; set; }
    /// <summary>Orientation.</summary>
    [Parameter] public RadioOrientation Orientation { get; set; } = RadioOrientation.Vertical;

    void IRadioContainer.RegisterOption(IRadioOption option)
    {
        if (_options.Contains(option)) { return; }
        _options.Add(option);
        StateHasChanged();
    }
    void IRadioContainer.UnregisterOption(IRadioOption option)
    {
        _options.Remove(option);
        StateHasChanged();
    }
    bool IRadioContainer.IsOptionSelected(object? value) => EqualityComparer<object>.Default.Equals(CurrentValue, value);
    async Task IRadioContainer.SelectOptionAsync(object? value) => await SelectValueAsync(value);
    Type IRadioContainer.ElementType => _elementType;

    public BOBInputRadio()
    {
        _elementType = typeof(TValue);
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _initialValue = Value ?? default!;
    }

    public override BOBInputRadioVariant DefaultVariant => BOBInputRadioVariant.Default;

    protected override IReadOnlyDictionary<BOBInputRadioVariant, Func<BOBInputRadio<TValue>, RenderFragment>> BuiltInTemplates { get; } =
        new Dictionary<BOBInputRadioVariant, Func<BOBInputRadio<TValue>, RenderFragment>>
        {
            [BOBInputRadioVariant.Default] = r => r.RenderDefault(),
        };

    protected override bool TryParseValueFromString(string? value, out TValue result, out string validationErrorMessage)
    {
        validationErrorMessage = string.Empty;
        result = default!;
        return true;
    }

    private async Task SelectValueAsync(object? value)
    {
        if (IsDisabled) return;
        CurrentValue = value == null ? default! : (TValue)value;
        await ValueChanged.InvokeAsync(CurrentValue);
    }

    private async Task ClearAsync()
    {
        if (IsDisabled || !Clearable) return;
        CurrentValue = IsNullableType ? default! : _initialValue;
        await ValueChanged.InvokeAsync(CurrentValue);
    }

    private bool HasValue => IsNullableType
        ? CurrentValue != null
        : !EqualityComparer<TValue>.Default.Equals(CurrentValue, _initialValue);

    private bool ShowClearButton => Clearable && HasValue && !IsDisabled;

    public void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes[FeatureDefinitions.DataAttributes.Orientation] = Orientation.ToString().ToLowerInvariant();
    }

    public void BuildComponentCssVariables(Dictionary<string, string> cssVariables) { }

    private RenderFragment RenderDefault() => __builder =>
    {
        <bob-component @attributes="ComputedAttributes">

            @if (!string.IsNullOrWhiteSpace(Label))
            {
                <span class="bob-radio__label">
                    @Label
                    @if (IsRequired)
                    {
                        <span class="bob-field__required">*</span>
                    }
                </span>
            }
    
            <div class="bob-radio__group" role="radiogroup">
                @foreach (IRadioOption option in _options)
                {
                    bool isSelected = ((IRadioContainer)this).IsOptionSelected(option.RawValue);
                    bool isOptionDisabled = IsDisabled || option.IsDisabled;
    
                    <div class="bob-radio__option @(isOptionDisabled ? "bob-radio__option--disabled" : "")"
                         role="radio"
                         aria-checked="@isSelected.ToString().ToLowerInvariant()"
                         aria-disabled="@isOptionDisabled.ToString().ToLowerInvariant()"
                         aria-describedby="@_helperTextId"
                         tabindex="@(isOptionDisabled ? -1 : 0)"
                         @onclick="() => HandleOptionClick(option, isOptionDisabled)"
                         @onkeydown="e => HandleOptionKeyDown(e, option, isOptionDisabled)"
                         @onkeydown:preventDefault="_preventKeyDefault">
    
                        <_BOBCheckMark Checked="@isSelected"
                                       Mode="_BOBCheckMark.CheckMarkMode.Radio"
                                       Size="Size"
                                       Disabled="isOptionDisabled"
                                       CheckedIcon="@CheckedIcon"
                                       UncheckedIcon="@UncheckedIcon" />
    
                        <span class="bob-radio__text">@option.Content</span>
                    </div>
                }
            </div>
    
            @if (ShowClearButton)
            {
                <_BOBBtn OnClick="ClearClicked">
                    @ClearText
                </_BOBBtn>
            }
    
            <_BOBFieldHelper TValue="TValue"
                             Id="@_helperTextId"
                             HelperText="@HelperText"
                             ShowValidation="@IsError"
                             EditContext="@EditContext"
                             For="@ValueExpression" />
    
        </bob-component>
    };

    private async Task HandleOptionClick(IRadioOption option, bool isDisabled)
    {
        if (isDisabled) return;
        await SelectValueAsync(option.RawValue);
    }

    private async Task HandleOptionKeyDown(KeyboardEventArgs e, IRadioOption option, bool isDisabled)
    {
        _preventKeyDefault = e.Key == " ";
        if ((e.Key == " " || e.Key == "Enter") && !isDisabled)
        {
            await SelectValueAsync(option.RawValue);
        }
    }

    private async Task ClearClicked(MouseEventArgs e) => await ClearAsync();
}