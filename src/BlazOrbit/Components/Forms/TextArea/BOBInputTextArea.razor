@using BlazOrbit.Abstractions
@using BlazOrbit.Utilities
@using Microsoft.JSInterop
@using System.Diagnostics.CodeAnalysis

@namespace BlazOrbit.Components.Forms
@attribute [GenerateComponentInfo]

@inherits BOBInputComponentBase<string, BOBInputTextArea, BOBInputVariant>
@implements IBuiltComponent
@implements IHasSize
@implements IHasLoading
@implements IHasDensity
@implements IHasShadow
@implements IHasColor
@implements IHasBackgroundColor
@implements IHasPrefix
@implements IHasSuffix
@implements IInputFamilyComponent

@inject ITextAreaJsInterop TextAreaJs

@{
    base.BuildRenderTree(__builder);
}

@code {
    private ElementReference _textareaRef;
    private string _textareaId = $"bob-textarea-{Guid.NewGuid():N}";
    private string _helperTextId = $"bob-helper-{Guid.NewGuid():N}";
    private bool _jsInitialized;
    private bool _isFocused;
    private bool _isDirty;

    // IHasSize
    /// <summary>Visual size of the textarea.</summary>
    [Parameter] public BOBSize Size { get; set; } = BOBSize.Medium;

    // IHasLoading
    /// <summary>When <see langword="true" />, the textarea shows a loading indicator.</summary>
    [Parameter] public bool Loading { get; set; }
    /// <summary>Variant of the loading indicator shown when <see cref="Loading"/> is <see langword="true"/>.</summary>
    [Parameter] public BOBLoadingIndicatorVariant LoadingIndicatorVariant { get; set; } = BOBLoadingIndicatorVariant.CircularProgress;

    // IHasDensity
    /// <summary>Vertical density (gap) of the textarea.</summary>
    [Parameter] public BOBDensity Density { get; set; } = BOBDensity.Standard;

    // IHasShadow
    /// <summary>Shadow style applied to the textarea container.</summary>
    [Parameter] public ShadowStyle? Shadow { get; set; }

    // IHasBackgroundColor
    /// <summary>Background color of the textarea. Accepts any valid CSS color value.</summary>
    [Parameter] public string? BackgroundColor { get; set; }

    // IHasColor
    /// <summary>Text color of the textarea. Accepts any valid CSS color value.</summary>
    [Parameter] public string? Color { get; set; }

    // IHasPrefix
    /// <summary>Text displayed before the textarea value.</summary>
    [Parameter] public string? PrefixText { get; set; }
    /// <summary>Material icon name for the Prefix.</summary>
    [Parameter] public IconKey? PrefixIcon { get; set; }
    /// <summary>Prefix color. Accepts any valid CSS color value.</summary>
    [Parameter] public string? PrefixColor { get; set; }
    /// <summary>PrefixBackground color. Accepts any valid CSS color value.</summary>
    [Parameter] public string? PrefixBackgroundColor { get; set; }

    // IHasSuffix
    /// <summary>Text displayed after the textarea value.</summary>
    [Parameter] public string? SuffixText { get; set; }
    /// <summary>Material icon name for the Suffix.</summary>
    [Parameter] public IconKey? SuffixIcon { get; set; }
    /// <summary>Suffix color. Accepts any valid CSS color value.</summary>
    [Parameter] public string? SuffixColor { get; set; }
    /// <summary>SuffixBackground color. Accepts any valid CSS color value.</summary>
    [Parameter] public string? SuffixBackgroundColor { get; set; }

    // Component-specific
    /// <summary>Floating label displayed above the textarea when it has a value or focus.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Placeholder text shown when the component is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Helper text displayed below the component for additional context.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Number of visible text rows.</summary>
    [Parameter] public int Rows { get; set; } = 3;
    /// <summary>
    /// Browser-enforced character cap, emitted as the <c>maxlength</c> HTML attribute.
    /// UI hint only — a malicious client (devtools, direct fetch, modified WASM) can
    /// bypass it. Always re-validate on the server before persisting the value.
    /// </summary>
    [Parameter] public int? MaxLength { get; set; }
    /// <summary>When <see langword="true" />, the textarea grows vertically as content is added.</summary>
    [Parameter] public bool AutoResize { get; set; }
    /// <summary>Direction the user is allowed to resize the textarea via the corner grip.</summary>
    [Parameter] public TextAreaResize Resize { get; set; } = TextAreaResize.Vertical;
    /// <summary>When <see langword="true" />, the bound value updates on every keystroke instead of on blur.</summary>
    [Parameter] public bool UpdateOnInput { get; set; }
    /// <summary>Raised on every keystroke when <see cref="UpdateOnInput"/> is enabled.</summary>
    [Parameter] public EventCallback<string> OnInput { get; set; }
    /// <summary>
    /// Trailing-edge debounce delay applied to <see cref="OnInput"/> only. When
    /// greater than <c>0</c>, the callback fires after this many milliseconds of
    /// keyboard inactivity, coalescing burst keystrokes into a single invocation.
    /// <c>0</c> disables debouncing (default). <see cref="UpdateOnInput"/> is
    /// unaffected: when enabled, the bound <see cref="InputBase{TValue}.Value"/>
    /// still propagates immediately per keystroke.
    /// </summary>
    [Parameter] public int OnInputDebounceMs { get; set; }

    private BOBDebouncer<string>? _onInputDebouncer;

    public override BOBInputVariant DefaultVariant => BOBInputVariant.Outlined;

    private bool HasValue => !string.IsNullOrEmpty(CurrentValue);
    private bool IsFloated => _isFocused || HasValue || _isDirty;

    public void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes[FeatureDefinitions.DataAttributes.Resize] = Resize.ToString().ToLowerInvariant();
        if (AutoResize)
            dataAttributes[FeatureDefinitions.DataAttributes.AutoResize] = "true";
        else
            dataAttributes.Remove(FeatureDefinitions.DataAttributes.AutoResize);
        if (IsFloated)
            dataAttributes[FeatureDefinitions.DataAttributes.Floated] = "true";
        else
            dataAttributes.Remove(FeatureDefinitions.DataAttributes.Floated);
    }

    public void BuildComponentCssVariables(Dictionary<string, string> cssVariables) { }

    protected override IReadOnlyDictionary<BOBInputVariant, Func<BOBInputTextArea, RenderFragment>> BuiltInTemplates { get; } =
        new Dictionary<BOBInputVariant, Func<BOBInputTextArea, RenderFragment>>
        {
            [BOBInputVariant.Outlined] = t => t.RenderTextArea(),
            [BOBInputVariant.Filled] = t => t.RenderTextArea(),
            [BOBInputVariant.Standard] = t => t.RenderTextArea()
        };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender && AutoResize)
        {
            try
            {
                await TextAreaJs.InitializeAutoResizeAsync(_textareaRef, _textareaId);
                _jsInitialized = true;
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (InvalidOperationException) { }
            catch (TaskCanceledException) { }
        }
    }

    private RenderFragment RenderTextArea() => __builder =>
    {
        <bob-component @attributes="ComputedAttributes">

            <div class="bob-input__wrapper">

                <BOBInputOutline Label="@Label" For="@_textareaId" Required="@IsRequired" />
                <BOBInputPrefix PrefixText="@PrefixText" PrefixIcon="@PrefixIcon" Size="@Size" />

                <textarea @ref="_textareaRef"
                          id="@_textareaId"
                          class="bob-input__field"
                          value="@CurrentValue"
                          rows="@Rows"
                          maxlength="@MaxLength"
                          placeholder="@(IsFloated? Placeholder : null)"
                          disabled="@IsDisabled"
                          readonly="@IsReadOnly"
                          required="@IsRequired"
                          @onchange="HandleChange"
                          @oninput="HandleInput"
                          @onfocus="HandleFocus"
                          @onblur="HandleBlur"
                          aria-label="@(string.IsNullOrWhiteSpace(Label) ? Placeholder : null)"
                          aria-describedby="@_helperTextId"
                          aria-invalid="@IsError.ToString().ToLowerInvariant()"
                          aria-required="@IsRequired.ToString().ToLowerInvariant()"></textarea>

                <BOBInputSuffix SuffixText="@SuffixText" SuffixIcon="@SuffixIcon" Size="@Size" />
                <BOBInputLoading Loading="@Loading" LoadingIndicatorVariant="@LoadingIndicatorVariant" Size="@Size" />

            </div>

            <_BOBFieldHelper TValue="string"
                             Id="@_helperTextId"
                             HelperText="@HelperText"
                             ShowValidation="@IsError"
                             EditContext="@EditContext"
                             For="@ValueExpression" />

        </bob-component>
    };

    private void HandleFocus(FocusEventArgs e)
    {
        _isFocused = true;
    }

    private void HandleBlur(FocusEventArgs e)
    {
        _isFocused = false;
        _isDirty = false;
    }

    private void HandleChange(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString() ?? string.Empty;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        string inputValue = e.Value?.ToString() ?? string.Empty;
        _isDirty = !string.IsNullOrEmpty(inputValue);

        if (UpdateOnInput)
        {
            CurrentValueAsString = inputValue;
        }

        if (!OnInput.HasDelegate)
        {
            return;
        }

        if (OnInputDebounceMs > 0)
        {
            _onInputDebouncer ??= new BOBDebouncer<string>(TimeSpan.FromMilliseconds(OnInputDebounceMs));
            await _onInputDebouncer.InvokeAsync(inputValue, v => OnInput.InvokeAsync(v));
        }
        else
        {
            _onInputDebouncer?.Cancel();
            await OnInput.InvokeAsync(inputValue);
        }
    }

    protected override bool TryParseValueFromString(string? value, [MaybeNullWhen(false)] out string result, [NotNullWhen(false)] out string? validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = null;
        return true;
    }

    public override async ValueTask DisposeAsync()
    {
        _onInputDebouncer?.Dispose();
        if (_jsInitialized)
        {
            await TextAreaJs.DisposeAutoResizeAsync(_textareaId);
        }
        await base.DisposeAsync();
    }
}