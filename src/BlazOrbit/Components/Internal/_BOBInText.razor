@namespace BlazOrbit.Components.Internal

<input type="text"
       class="@ComputedClass"
       value="@Value"
       placeholder="@Placeholder"
       disabled="@Disabled"
       aria-label="@AriaLabel"
       @onchange="HandleChange"
       @oninput="HandleInput"
       @attributes="FilteredAttributes" />

@code {
    /// <summary>Current value of the component.</summary>
    [Parameter] public string? Value { get; set; }
    /// <summary>Raised when the value changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    /// <summary>Placeholder text shown when the component is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>When <see langword="true" />, the component is non-interactive.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Accessible name for the component.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>UpdateOnInput.</summary>
    [Parameter] public bool UpdateOnInput { get; set; }
    /// <summary>Raised on every keystroke when <see cref="UpdateOnInput"/> is enabled.</summary>
    [Parameter] public EventCallback<string?> OnInput { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass
    {
        get
        {
            if (AdditionalAttributes?.TryGetValue("class", out object? extra) == true && extra is string s && !string.IsNullOrWhiteSpace(s))
            {
                return $"_bob-simple-input {s}";
            }
            return "_bob-simple-input";
        }
    }

    private Dictionary<string, object>? FilteredAttributes
        => AdditionalAttributes?.Where(kv => kv.Key != "class").ToDictionary(kv => kv.Key, kv => kv.Value);

    private async Task HandleChange(ChangeEventArgs e)
    {
        string? newValue = e.Value?.ToString();
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        string? newValue = e.Value?.ToString();

        if (UpdateOnInput)
        {
            Value = newValue;
            await ValueChanged.InvokeAsync(newValue);
        }

        if (OnInput.HasDelegate)
            await OnInput.InvokeAsync(newValue);
    }
}