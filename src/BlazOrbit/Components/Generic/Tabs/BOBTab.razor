@namespace BlazOrbit.Components
@attribute [GenerateComponentInfo]
@implements IDisposable

@if (Parent?.IsActiveTab(Id) == true)
{
    @ChildContent
}

@code {
    [CascadingParameter] public BOBTabs? Parent { get; set; }

    [Parameter, EditorRequired] public string? Id { get; set; }

    [Parameter, EditorRequired] public string? Label { get; set; }

    /// <summary>Material icon name for the .</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    /// <summary>Content rendered inside the component.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>When <see langword="true" />, the component is non-interactive.</summary>
    [Parameter] public bool Disabled { get; set; }

    protected override void OnInitialized()
    {
        Parent?.RegisterTab(this);
    }

    public void Dispose()
    {
        Parent?.UnregisterTab(this);
    }
}