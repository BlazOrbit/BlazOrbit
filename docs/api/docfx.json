{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../src",
          "files": [
            "BlazOrbit/bin/Release/net10.0/BlazOrbit.dll",
            "BlazOrbit.Core/bin/Release/net10.0/BlazOrbit.Core.dll",
            "BlazOrbit.SyntaxHighlight/bin/Release/net10.0/BlazOrbit.SyntaxHighlight.dll",
            "BlazOrbit.Localization.Shared/bin/Release/net10.0/BlazOrbit.Localization.Shared.dll",
            "BlazOrbit.Localization.Server/bin/Release/net10.0/BlazOrbit.Localization.Server.dll",
            "BlazOrbit.Localization.Wasm/bin/Release/net10.0/BlazOrbit.Localization.Wasm.dll",
            "BlazOrbit.Translations/bin/Release/net10.0/BlazOrbit.Translations.dll",
            "BlazOrbit.FluentValidation/bin/Release/net10.0/BlazOrbit.FormsFluentValidation.dll"
          ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "net10.0",
        "Configuration": "Release"
      },
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "memberLayout": "samePage",
      "outputFormat": "mref"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["index.md", "toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "BlazOrbit API reference",
      "_appTitle": "BlazOrbit API",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.png",
      "_appFooter": "Generated with <a href=\"https://dotnet.github.io/docfx\">DocFX</a> from <a href=\"https://github.com/BlazOrbit/BlazOrbit\">BlazOrbit/BlazOrbit</a>",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/BlazOrbit/BlazOrbit",
        "branch": "master"
      },
      "pdf": false
    },
    "template": ["default", "modern"],
    "xref": [],
    "xrefService": [
      "https://xref.docs.microsoft.com/query?uid={uid}"
    ]
  }
}
