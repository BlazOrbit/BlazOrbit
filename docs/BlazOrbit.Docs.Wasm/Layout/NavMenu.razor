@inject IStringLocalizer<NavMenu> Loc
@inject NavigationManager NavigationManager

<DocSearch />

<BOBTreeMenu @ref="_treeMenu"
             TItem="object"
             Size="BOBSize.Medium"
             @bind-ExpandedKeys="_expandedKeys">
    <BOBTreeMenuItem Text="@Loc["Getting Started"]"
                     Key="nav-getting-started"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_rocket_launch"
                     Href="/getting-started">
    </BOBTreeMenuItem>

    <BOBTreeMenuItem Text="@Loc["Components"]"
                     Key="nav-components"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_widgets"
                     InitiallyExpanded="true">
        <ChildContent>
            <BOBTreeMenuItem Text="@Loc["Forms"]"
                             Key="nav-forms"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_edit_note"
                             InitiallyExpanded="true"
                             Href="/components/forms"
                             OnClick="@NavigateToForms">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Checkbox"]" Href="/components/forms/checkbox" />
                    <BOBTreeMenuItem Text="@Loc["Color Picker"]" Href="/components/forms/color" />
                    <BOBTreeMenuItem Text="@Loc["DateTime"]" Href="/components/forms/datetime" />
                    <BOBTreeMenuItem Text="@Loc["Dropdown"]" Href="/components/forms/dropdown" />
                    <BOBTreeMenuItem Text="@Loc["Number"]" Href="/components/forms/number" />
                    <BOBTreeMenuItem Text="@Loc["Number Slider"]" Href="/components/forms/numberslider" />
                    <BOBTreeMenuItem Text="@Loc["Radio"]" Href="/components/forms/radio" />
                    <BOBTreeMenuItem Text="@Loc["Range Slider"]" Href="/components/forms/rangeslider" />
                    <BOBTreeMenuItem Text="@Loc["Switch"]" Href="/components/forms/switch" />
                    <BOBTreeMenuItem Text="@Loc["Text"]" Href="/components/forms/text" />
                    <BOBTreeMenuItem Text="@Loc["TextArea"]" Href="/components/forms/textarea" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Actions"]"
                             Key="nav-actions"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_touch_app">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Button"]" Href="/components/actions/button" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Layout & Containers"]"
                             Key="nav-layout-containers"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_view_quilt">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Accordion"]" Href="/components/layout/accordion" />
                    <BOBTreeMenuItem Text="@Loc["Card"]" Href="/components/layout/card" />
                    <BOBTreeMenuItem Text="@Loc["Flex Stack"]" Href="/components/layout/flex-stack" />
                    <BOBTreeMenuItem Text="@Loc["Grid"]" Href="/components/layout/grid" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Navigation"]"
                             Key="nav-navigation"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_explore">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Tabs"]" Href="/components/navigation/tabs" />
                    <BOBTreeMenuItem Text="@Loc["Tree Menu"]" Href="/components/navigation/treemenu" />
                    <BOBTreeMenuItem Text="@Loc["Tree Selector"]" Href="/components/navigation/treeselector" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Data Display"]"
                             Key="nav-data-display"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_table_chart">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Code Block"]" Href="/components/data/codeblock" />
                    <BOBTreeMenuItem Text="@Loc["DataCards"]" Href="/components/data/datacards" />
                    <BOBTreeMenuItem Text="@Loc["DataGrid"]" Href="/components/data/datagrid" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Display & Media"]"
                             Key="nav-display-media"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_palette">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Badge"]" Href="/components/display/badge" />
                    <BOBTreeMenuItem Text="@Loc["Carousel"]" Href="/components/display/carousel" />
                    <BOBTreeMenuItem Text="@Loc["Loading"]" Href="/components/display/loading" />
                    <BOBTreeMenuItem Text="@Loc["Svg Icon"]" Href="/components/display/svgicon" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Overlays & Feedback"]"
                             Key="nav-overlays-feedback"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_chat_bubble_outline">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Dialog & Drawer"]" Href="/components/overlays/modal" />
                    <BOBTreeMenuItem Text="@Loc["Toast"]" Href="/components/overlays/toast" />
                    <BOBTreeMenuItem Text="@Loc["Tooltip"]" Href="/components/overlays/tooltip" />
                </ChildContent>
            </BOBTreeMenuItem>

            <BOBTreeMenuItem Text="@Loc["Utilities"]"
                             Key="nav-utilities"
                             Icon="@BOBIconKeys.MaterialIconsOutlined.i_handyman">
                <ChildContent>
                    <BOBTreeMenuItem Text="@Loc["Draggable"]" Href="/components/utilities/draggable" />
                    <BOBTreeMenuItem Text="@Loc["Theme Selector"]" Href="/components/utilities/themeselector" />
                </ChildContent>
            </BOBTreeMenuItem>

        </ChildContent>
    </BOBTreeMenuItem>

    <BOBTreeMenuItem Text="@Loc["Features"]"
                     Key="nav-features"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_featured_play_list">
        <ChildContent>
            <BOBTreeMenuItem Text="@Loc["Validation"]" Href="/features/validation" />
            <BOBTreeMenuItem Text="@Loc["Localization"]" Href="/features/localization" />
            <BOBTreeMenuItem Text="@Loc["Icon Gallery"]" Href="/features/icons" />

        </ChildContent>
    </BOBTreeMenuItem>

    <BOBTreeMenuItem Text="@Loc["Utils"]"
                     Key="nav-utils"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_build">
        <ChildContent>
            <BOBTreeMenuItem Text="@Loc["Theme Generator"]" Href="/utils/themegenerator" />
        </ChildContent>
    </BOBTreeMenuItem>

    <BOBTreeMenuItem Text="@Loc["Developer"]"
                     Key="nav-developer"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_code"
                     InitiallyExpanded="true">
        <ChildContent>
            <BOBTreeMenuItem Text="@Loc["Architecture"]" Href="/concepts/architecture" />
            <BOBTreeMenuItem Text="@Loc["Variants"]" Href="/concepts/variants" />
            <BOBTreeMenuItem Text="@Loc["Theming"]" Href="/concepts/theming" />
            <BOBTreeMenuItem Text="@Loc["JS Interop"]" Href="/concepts/js-interop" />
            <BOBTreeMenuItem Text="@Loc["Accessibility"]" Href="/concepts/accessibility" />

        </ChildContent>
    </BOBTreeMenuItem>
    <BOBTreeMenuItem Text="@Loc["Live Development"]"
                     Key="nav-live-development"
                     Icon="@BOBIconKeys.MaterialIconsOutlined.i_code"
                     Href="/live-development"
                     OnClick="@NavigateToLiveDevelopment">
    </BOBTreeMenuItem>
</BOBTreeMenu>
<DocFooter />

@code {
    private BOBTreeMenu<object>? _treeMenu;
    private HashSet<string> _expandedKeys = new();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;

        _expandedKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "nav-components",
            "nav-developer",
            "nav-forms",
        };
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_treeMenu is null)
            return;

        string route = NavigationManager.ToBaseRelativePath(e.Location);
        if (string.IsNullOrEmpty(route))
            route = "/";

        string absoluteRoute = route.StartsWith('/') ? route : "/" + route;

        var node = _treeMenu.GetNode(absoluteRoute);
        if (node is null)
            return;

        var current = node;
        bool changed = false;

        while (current?.ParentNode is not null)
        {
            string parentKey = current.ParentNode.Key;
            if (_expandedKeys.Add(parentKey))
                changed = true;
            current = current.ParentNode;
        }

        if (changed)
            StateHasChanged();
    }

    private void NavigateToForms()
    {
        NavigationManager.NavigateTo("/components/forms");
    }

    private void NavigateToLiveDevelopment()
    {
        NavigationManager.NavigateTo("/live-development");
    }
}
