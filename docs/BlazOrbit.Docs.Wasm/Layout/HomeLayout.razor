@inherits LayoutComponentBase

<BOBInitializer DefaultTheme="dark">
    <div class="home-layout">
        <header class="home-layout__header">
            <a class="doc-header__brand" href="/">
                <img src="icon-48.png" aria-hidden="true" />
            </a>
            <nav class="doc-header__actions">
                <a class="doc-header__link" href="https://discord.gg/CmBtHkn2zn" target="_blank" rel="noopener">
                    <BOBSvgIcon Icon="BOBIconKeys.Brands.Discord" />
                </a>
                <a class="doc-header__link" href="https://github.com/BlazOrbit/BlazOrbit" target="_blank" rel="noopener">
                    <BOBSvgIcon Icon="BOBIconKeys.Brands.GitHub" />
                </a>
                <BlazOrbit.Components.Wasm.BOBCultureSelector Size="BOBSize.Small"
                                                              Variant="BOBCultureSelectorVariant.Dropdown"
                                                              ForceReload="true" style="--_input-border-color: 0px;" />
                <BOBThemeSelector Variant="BOBThemeSelectorVariant.SunMoon" />
            </nav>
        </header>

        <main class="home-layout__main">
            @Body
        </main>
        <DocFooter />
    </div>
</BOBInitializer>

<BOBModalHost />
<BOBToastHost MaxVisiblePerPosition="5" />
