@page "/components/modal"

@inject IStringLocalizer<ModalPage> Loc

<PageTitle>BlazOrbit - BOBDialog & BOBDrawer</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["Dialog & Drawer"]"
         Lede="@Loc["Accessible modals — centered dialogs and edge-anchored drawers. Both usable declaratively or via IModalService."]"
         PageInstance="this"
         ApiType="@typeof(BOBModalHost)">

    <DocDemo Key="BasicDialog" Title="@Loc["Basic dialog"]">
        <BOBButton Text="@Loc["Open dialog"]" OnClick="@(() => _basic = true)" />
        <BOBDialog @bind-Open="_basic" Title="@Loc["Hello"]">
            <Content>
                <p>@Loc["This is a basic dialog. Press Escape or click outside to close."]</p>
            </Content>
        </BOBDialog>
    </DocDemo>

    <DocDemo Key="FooterDialog" Title="@Loc["With header + footer"]">
        <BOBButton Text="@Loc["Open dialog with footer"]" OnClick="@(() => _footer = true)" />
        <BOBDialog @bind-Open="_footer" Title="@Loc["Confirm action"]">
            <Content>
                <p>@Loc["Are you sure you want to proceed?"]</p>
            </Content>
            <Footer>
                    <BOBButton Text="@Loc["Cancel"]" OnClick="@(() => _footer = false)" />
                    <BOBButton Text="@Loc["Confirm"]"
                               BackgroundColor="@PaletteColor.Primary"
                               Color="@PaletteColor.PrimaryContrast"
                               OnClick="@(() => _footer = false)" />
            </Footer>
        </BOBDialog>
    </DocDemo>

    <DocDemo Key="Dimensions" Title="@Loc["Dimensions"]" Description="@Loc["Use MinWidth, MaxWidth, MinHeight, MaxHeight, or FullScreen."]">
        <BOBButton Text="@Loc["Constrained dialog"]" OnClick="@(() => _dims = true)" />
        <BOBDialog @bind-Open="_dims" Title="@Loc["400 × 300 min, 600 × 500 max"]"
                   MinWidth="400px" MaxWidth="600px"
                   MinHeight="300px" MaxHeight="500px">
            <Content>
                <p>@Loc["This dialog has custom min/max width and height constraints."]</p>
            </Content>
        </BOBDialog>
    </DocDemo>

    <DocDemo Key="CloseOptions" Title="@Loc["Close options"]" Description="@Loc["Toggle Closable, CloseOnOverlayClick, and CloseOnEscape."]">
        <BOBButton Text="@Loc["Uncloseable dialog"]" OnClick="@(() => _closeOpts = true)" />
        <BOBDialog @bind-Open="_closeOpts"
                   Title="@Loc["Explicit close only"]"
                   Closable="false"
                   CloseOnOverlayClick="false"
                   CloseOnEscape="false">
            <Content>
                <p>@Loc["The header X, overlay click, and Escape are all disabled. The only way out is the button below."]</p>
            </Content>
            <Footer>
                <BOBButton Text="@Loc["Close"]"
                           BackgroundColor="@PaletteColor.Primary"
                           Color="@PaletteColor.PrimaryContrast"
                           OnClick="@(() => _closeOpts = false)" />
            </Footer>
        </BOBDialog>
    </DocDemo>

    <DocDemo Key="DrawerPositions" Title="@Loc["Drawer positions"]">
            <BOBButton Text="@Loc["Left"]" OnClick="@(() => _left = true)" />
            <BOBButton Text="@Loc["Right"]" OnClick="@(() => _right = true)" />
            <BOBButton Text="@Loc["Top"]" OnClick="@(() => _top = true)" />
            <BOBButton Text="@Loc["Bottom"]" OnClick="@(() => _bottom = true)" />

        <BOBDrawer @bind-Open="_left" Position="DrawerPosition.Left">
            <ChildContent>
                <h3>@Loc["Left drawer"]</h3>
                <p>@Loc["Slides in from the left."]</p>
            </ChildContent>
        </BOBDrawer>

        <BOBDrawer @bind-Open="_right" Position="DrawerPosition.Right">
            <ChildContent>
                <h3>@Loc["Right drawer"]</h3>
                <p>@Loc["Slides in from the right."]</p>
            </ChildContent>
        </BOBDrawer>

        <BOBDrawer @bind-Open="_top" Position="DrawerPosition.Top">
            <ChildContent>
                <h3>@Loc["Top drawer"]</h3>
                <p>@Loc["Slides down from the top."]</p>
            </ChildContent>
        </BOBDrawer>

        <BOBDrawer @bind-Open="_bottom" Position="DrawerPosition.Bottom">
            <ChildContent>
                <h3>@Loc["Bottom drawer"]</h3>
                <p>@Loc["Slides up from the bottom."]</p>
            </ChildContent>
        </BOBDrawer>
    </DocDemo>

    <DocDemo Key="Elevation" Title="@Loc["Elevation"]" Description="@Loc["Material Design elevation level (0–24). Derives shadow and dark-mode surface tint automatically."]">
        <BOBButton Text="@Loc["Open elevated dialog"]" OnClick="@(() => _elevationDialog = true)" />
        <BOBDialog @bind-Open="_elevationDialog" Title="@Loc["Elevated dialog"]" Elevation="4">
            <Content>
                <p>@Loc["This dialog uses Elevation=4 for medium emphasis."]</p>
            </Content>
        </BOBDialog>

        <BOBButton Text="@Loc["Open elevated drawer"]" OnClick="@(() => _elevationDrawer = true)" />
        <BOBDrawer @bind-Open="_elevationDrawer" Position="DrawerPosition.Right" Elevation="8">
            <ChildContent>
                <h3>@Loc["Elevated drawer"]</h3>
                <p>@Loc["This drawer uses Elevation=8 for high emphasis."]</p>
            </ChildContent>
        </BOBDrawer>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Programmatic API"]</h2>
        <p class="doc-section__description">@Loc["Inject IModalService and call ShowDialogAsync / ShowDrawerAsync."]</p>
        <BOBCodeBlock Language="SyntaxHighlightLanguage.CSharp" Code="@_serviceCode" Title="Program.cs + usage" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BOBDialog</h3>
        <PropertyTable Properties="@BOBDialogComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BOBDrawer</h3>
        <PropertyTable Properties="@BOBDrawerComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private bool _basic;
    private bool _footer;
    private bool _dims;
    private bool _closeOpts;
    private bool _left;
    private bool _right;
    private bool _top;
    private bool _bottom;
    private bool _elevationDialog;
    private bool _elevationDrawer;

    private const string _serviceCode = @"// Register in Program.cs
services.AddBlazOrbit(); // includes IModalService

// Inject and call
@inject IModalService ModalService

private async Task Show()
{
    var result = await ModalService.ShowDialogAsync<MyConfirmDialog, bool?>(
        null,
        new DialogOptions { Title = ""Confirm"", MaxWidth = ""400px"" });
}

// Inside MyConfirmDialog.razor
@implements IModalContent
[CascadingParameter] public ModalReference ModalReference { get; set; } = default!;

<BOBButton Text=""Yes"" OnClick=""() => ModalReference.CloseAsync(true)"" />
<BOBButton Text=""No""  OnClick=""() => ModalReference.CloseAsync(false)"" />";
}
